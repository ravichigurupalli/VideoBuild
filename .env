# Copy to .env and adjust
VIDEO_TITLE_PREFIX=Daily Update
VIDEO_DESCRIPTION=Automated daily upload
VIDEO_PRIVACY=private
SECONDS_PER_IMAGE=4
RESOLUTION_WIDTH=1920
RESOLUTION_HEIGHT=1080
BITRATE=4000k
FPS=30
CATEGORY_ID=22
AUDIO_VOLUME=0.6
BGM_VOLUME=0.35
BGM_VOLUME_WITH_VOICE=0.15
OUTPUT_FILENAME=output.mp4
ENABLE_TTS=true
TTS_VOICE=HKEY_LOCAL_MACHINE\SOFTWARE\Microsoft\Speech\Voices\Tokens\TTS_MS_EN-US_DAVID_11.0
TTS_RATE=165
ENABLE_CAPTIONS=true
CAPTION_FONT_SIZE=84
CAPTION_WORDS_PER_CHUNK=4
CAPTION_POP_SCALE=1.0

